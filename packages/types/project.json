{
  "name": "@poc/types",
  "root": "packages/types",
  "sourceRoot": "packages/types/src",
  "projectType": "library",
  "tags": ["type:package"],
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "options": {
        "outputPath": "dist/packages/types",
        "main": "packages/types/src/index.ts",
        "tsConfig": "packages/types/tsconfig.json",
        "assets": []
      }
    },
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc -p packages/types/tsconfig.json --watch",
        "cwd": "{workspaceRoot}"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "options": { "lintFilePatterns": ["packages/types/**/*.ts"] }
    }
  }
}
